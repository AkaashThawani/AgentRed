# AgentRed frontend — copy to `.env.local` and fill in.

# Backend URL — set to your Render URL in prod, localhost in dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: deep links shown as small chips in the header so judges can click
# straight to the live sponsor dashboards. Leave blank to hide the chips.
NEXT_PUBLIC_DATADOG_DASHBOARD_URL=
NEXT_PUBLIC_CLICKHOUSE_CONSOLE_URL=
