# AgentRed backend — copy to `.env` and fill in the values you have.
# Anything left blank is treated as "not configured" and that integration is skipped silently.

# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_KEY=

# ─── OPTIONAL: model overrides ───────────────────────────────────────────────
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_REASONING=gemini-2.5-pro

# ─── OPTIONAL: ClickHouse (sponsor — historical trust scores + leaderboard) ──
# Sign up free at https://clickhouse.cloud. After provisioning a service, the
# dashboard shows the hostname and an auto-generated password.
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# ─── OPTIONAL: Datadog (sponsor — real-time scan metrics) ────────────────────
# Free tier, no credit card. Get the API key at:
#   https://app.datadoghq.com  →  Organization Settings  →  API Keys
# Site is `datadoghq.com` for US1, `datadoghq.eu` for EU1, `us3.datadoghq.com` for US3, etc.
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ─── OPTIONAL: scan tunables ─────────────────────────────────────────────────
HTTP_TIMEOUT_S=20
MAX_CONCURRENT_TESTS=3
TESTS_PER_SKILL=7
MAX_TOTAL_TESTS=25
ADAPTIVE_FOLLOWUP_COUNT=2
